# Invoke URL: API Gateway → Stages → $default → Invoke URL + /upload
VITE_UPLOAD_API_URL=https://xxxxxxxx.execute-api.us-east-2.amazonaws.com/upload

# Bucket S3 (mismo nombre que BUCKET_NAME en la Lambda)
VITE_S3_BUCKET=cloudpix-fredy-2026-866017706103-us-east-2-an

# Región AWS (debe coincidir con S3, Lambda y API Gateway)
VITE_AWS_REGION=us-east-2

# AWS Cognito — Login
# Cognito → User Pools → tu pool → Overview
VITE_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
# Cognito → User Pools → tu pool → App clients
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# Opcional: si es distinta a VITE_AWS_REGION
# VITE_COGNITO_REGION=us-east-2
