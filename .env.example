# URL del API Gateway que invoca la Lambda de URLs prefirmadas
VITE_UPLOAD_API_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com/upload

# Bucket S3 donde se guardan las imágenes (solo referencia en el frontend)
VITE_S3_BUCKET=mi-bucket-imagenes

# Región AWS del bucket
VITE_AWS_REGION=us-east-1
